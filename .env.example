# ── Database ──
POSTGRES_DB=socialmedia
POSTGRES_USER=socialmedia_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Ports ──
DB_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=3000
